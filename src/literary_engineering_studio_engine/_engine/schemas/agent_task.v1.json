{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "literary-engineering-workbench/agent-task/v1",
  "title": "CLI-mediated platform-agent task",
  "type": "object",
  "required": [
    "schema",
    "task_id",
    "status",
    "route",
    "current_state",
    "task_type",
    "prompt_asset_id",
    "required_reading",
    "source_paths",
    "expected_outputs",
    "submission_command",
    "completion_command",
    "validation_gates",
    "forbidden_shortcuts"
  ],
  "properties": {
    "schema": {
      "const": "literary-engineering-workbench/agent-task/v1"
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": ["issued", "opened", "submitted", "blocked", "complete"]
    },
    "created_at": {
      "type": "string"
    },
    "opened_at": {
      "type": "string"
    },
    "completed_at": {
      "type": "string"
    },
    "route": {
      "type": "string"
    },
    "scene_id": {
      "type": "string"
    },
    "scene": {
      "type": "string"
    },
    "current_state": {
      "type": "string"
    },
    "task_type": {
      "type": "string"
    },
    "prompt_asset_id": {
      "type": "string"
    },
    "prompt_asset": {
      "type": "object",
      "required": [
        "requested_id",
        "resolved_id",
        "version",
        "required_inputs",
        "context_groups",
        "hard_constraints",
        "output_contract",
        "review_requirements",
        "forbidden_shortcuts",
        "body"
      ],
      "properties": {
        "requested_id": {"type": "string"},
        "resolved_id": {"type": "string"},
        "exact": {"type": "boolean"},
        "match": {"type": "string"},
        "version": {"type": "string"},
        "route": {"type": "string"},
        "task_type": {"type": "string"},
        "title": {"type": "string"},
        "body": {"type": "string"},
        "required_inputs": {"type": "array", "items": {"type": "string"}},
        "optional_inputs": {"type": "array", "items": {"type": "string"}},
        "context_groups": {"type": "array", "items": {"type": "string"}},
        "hard_constraints": {"type": "array", "items": {"type": "string"}},
        "style_constraints": {"type": "array", "items": {"type": "string"}},
        "output_contract": {"type": "array", "items": {"type": "string"}},
        "review_requirements": {"type": "array", "items": {"type": "string"}},
        "forbidden_shortcuts": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    },
    "execution_policy": {
      "enum": ["deterministic", "agent-required", "human-required"]
    },
    "agent_role": {
      "type": "string",
      "minLength": 1
    },
    "human_gate": {
      "type": "object",
      "required": ["required", "reasons", "source"],
      "properties": {
        "required": {"type": "boolean"},
        "reasons": {"type": "array", "items": {"type": "string"}},
        "source": {"type": "string"}
      },
      "additionalProperties": false
    },
    "runtime_capabilities_required": {
      "type": "array",
      "items": {"type": "string"}
    },
    "output_contracts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "kind", "writeback_policy"],
        "properties": {
          "path": {"type": "string"},
          "kind": {"type": "string"},
          "writeback_policy": {
            "enum": ["automatic", "preview-required", "approval-required", "none"]
          }
        },
        "additionalProperties": false
      }
    },
    "command": {
      "type": "string"
    },
    "required_reading": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "context_trace": {
      "type": "string"
    },
    "hard_constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "style_constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "word_count_target": {
      "type": "integer",
      "minimum": 0
    },
    "word_count_min": {
      "type": "integer",
      "minimum": 0
    },
    "word_count_max": {
      "type": "integer",
      "minimum": 0
    },
    "expected_outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "submission_command": {
      "type": "string"
    },
    "completion_command": {
      "type": "string"
    },
    "validation_gates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbidden_shortcuts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_allowed_states": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "task_json": {
      "type": "string"
    },
    "task_markdown": {
      "type": "string"
    },
    "submission": {
      "type": "string"
    },
    "submitted_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "completion": {
      "type": "string"
    },
    "validation": {
      "type": "object"
    }
  },
  "additionalProperties": true
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ArcVellum",
  "version": "0.9.2",
  "identifier": "cn.literary-engineering.studio",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": "default-src 'self' http://127.0.0.1:*; connect-src 'self' http://127.0.0.1:*; img-src 'self' data: http://127.0.0.1:*; style-src 'self' 'unsafe-inline' http://127.0.0.1:*; script-src 'self' 'unsafe-inline' http://127.0.0.1:*"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "externalBin": ["binaries/literary-engineering-studio-sidecar"],
    "resources": ["resources/opencode.exe", "resources/OPENCODE-NOTICE.md", "resources/OPENCODE-LICENSE.txt"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "languages": ["SimpChinese", "English"]
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc3REQzMUI3QTIzMjU3RTcKUldUblZ6S2l0ekhkZCsvTFZGOElJUzhUc0ozYklqb3FNSVVybGIwbGQwSXdReCsxMjYxMGpzcFAK",
      "endpoints": [
        "https://github.com/o-1717986918/arcvellum/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
